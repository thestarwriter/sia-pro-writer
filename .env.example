# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get this from https://app.lemonsqueezy.com
# Used to verify webhook signatures
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret-here

# Your Lemon Squeezy store slug and product variant ID
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_VARIANT_ID=your-variant-id

# A long random string — used to sign free-tier usage tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your-random-secret-here
